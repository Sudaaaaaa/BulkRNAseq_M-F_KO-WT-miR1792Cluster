### Genome-wide KOxIRI interaction + per-sex injury DEG (limma-voom, blocked)
# ********************************************************************************
# ---- fig-interaction-injury ----
# ********************************************************************************
fit_by_sex <- function(sx, formula) {
  s <- droplevels(sheet[sheet$sex == sx, ])
  dge <- calcNormFactors(DGEList(counts_f[, rownames(s)]))
  design <- model.matrix(formula, data = s)
  v  <- voom(dge, design)
  dc <- duplicateCorrelation(v, design, block = s$animal)
  v  <- voom(dge, design, block = s$animal, correlation = dc$consensus)
  dc <- duplicateCorrelation(v, design, block = s$animal)
  eBayes(lmFit(v, design, block = s$animal, correlation = dc$consensus))
}
#injury DEG (IRI vs CON) per sex
injF <- fit_by_sex("F", ~ condition); injM <- fit_by_sex("M", ~ condition)
ttF <- topTable(injF, coef="conditionIRI", number=Inf); ttF$gene <- id2sym[rownames(ttF)]
ttM <- topTable(injM, coef="conditionIRI", number=Inf); ttM$gene <- id2sym[rownames(ttM)]
common <- intersect(rownames(ttF), rownames(ttM))
r_conc <- cor(ttF[common,"logFC"], ttM[common,"logFC"])
cat(sprintf("Injury DEG FDR<0.05: F=%d M=%d ; concordance r=%.3f\n",
            sum(ttF$adj.P.Val<0.05), sum(ttM$adj.P.Val<0.05), r_conc))

#volcano per sex, JAK/STAT markers labeled
mk_id <- unlist(sym2id[markers8])
volc <- function(tt, title) {
  tt$sig <- tt$adj.P.Val < 0.05
  tt$mk  <- id2sym[rownames(tt)] %in% markers8
  ggplot(tt, aes(logFC, -log10(P.Value))) +
    geom_point(aes(color = sig), size = 0.6, alpha = 0.4) +
    geom_point(data = subset(tt, mk), shape = 21, size = 2.5, color = "#185FA5", fill = NA) +
    scale_color_manual(values = c(`TRUE`="#C0392B",`FALSE`="grey80"), guide="none") +
    ggrepel::geom_text_repel(data = subset(tt, mk), aes(label = id2sym[rownames(subset(tt, mk))]),
                             fontface = "italic", size = 3) +
    labs(x="log2 FC (IRI vs CON)", y="-log10 p", title=title) + theme_bw(base_size=11)
}
