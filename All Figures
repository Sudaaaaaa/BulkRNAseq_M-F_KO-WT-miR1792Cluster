## per-group paired IRI vs CON (limma-voom) -> rank by t -> fgsea
cp <- c("CP:KEGG_MEDICUS","CP:KEGG_LEGACY","CP:REACTOME","CP:WIKIPATHWAYS")
m2cp <- m2[m2$gs_subcollection %in% cp, ]
gs_df <- rbind(mh[,c("gs_name","gene_symbol")], m2cp[,c("gs_name","gene_symbol")])
pathways <- split(gs_df$gene_symbol, gs_df$gs_name)
group_rank <- function(g) {
  s <- droplevels(sheet[sheet$group == g, ])
  tab <- table(s$animal, s$condition)
  pa  <- rownames(tab)[tab[,"CON"] > 0 & tab[,"IRI"] > 0]
  s <- s[s$animal %in% pa, ]; s$animal <- droplevels(s$animal)
  if (nlevels(s$condition) < 2) return(NULL)
  dge <- normLibSizes(DGEList(counts_f[, rownames(s)]))
  des <- model.matrix(~ animal + condition, data = s)
  v <- voom(dge, des); fit <- eBayes(lmFit(v, des))
  tt <- topTable(fit, coef = "conditionIRI", number = Inf)
  r  <- tt$t
  nm <- id2sym[rownames(tt)]
  ok <- !is.na(nm) & nm != "" & !duplicated(nm)
  r  <- r[ok]; names(r) <- nm[ok]
  r  <- r[is.finite(r)]
  sort(r, decreasing = TRUE)
}
groups <- c("F_WT","F_KO","M_WT","M_KO")
gsea <- lapply(setNames(groups, groups), function(g){
  r <- group_rank(g); if (is.null(r)) return(NULL)
  x <- fgsea(pathways, r, minSize=10, maxSize=500); x$group <- g; x })
allg <- do.call(rbind, lapply(gsea, function(x) x[,c("group","pathway","NES","padj","size")]))
top_per <- unique(unlist(lapply(gsea, function(x){ x<-x[x$padj<0.05,]; head(x$pathway[order(x$padj)],10)})))
disp <- allg[allg$pathway %in% top_per, ]
disp$group <- factor(disp$group, levels = groups)

## ---- labels + plot (single version) ----
library(stringr)
disp$lab <- gsub("_"," ", sub("^(HALLMARK|KEGG_MEDICUS|KEGG_LEGACY|KEGG|REACTOME|WP)_","", disp$pathway))
disp$lab <- ifelse(nchar(disp$lab) > 60, paste0(substr(disp$lab, 1, 57), "..."), disp$lab)
disp$lab <- str_wrap(disp$lab, width = 34)

